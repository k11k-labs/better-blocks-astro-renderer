---
import { renderMermaidSVG, THEMES } from 'beautiful-mermaid';
import type { CustomBlocksConfig, DiagramNode, DiagramTheme } from './types';

interface Props {
  node: DiagramNode;
  blocks?: CustomBlocksConfig;
  diagramTheme?: DiagramTheme;
}

const { node, blocks, diagramTheme } = Astro.props;

const source = node.value ?? '';
const format = node.format ?? 'mermaid';
const DiagramComp = blocks?.diagram;

// Resolve the color palette passed to beautiful-mermaid. Without one it renders
// monochrome (every color is derived from a single dark `fg`). The built-in
// themes only set an accent, which colors arrows but leaves node fills/borders
// near-white — so our default mirrors mermaid.js's familiar look: lavender node
// fills (`surface`) with purple borders (`border`) and dark edges (`line`). A
// theme name selects a built-in palette; an object is used as custom colors.
const DEFAULT_DIAGRAM_COLORS = {
  bg: '#ffffff',
  fg: '#333333',
  line: '#333333',
  accent: '#9370db',
  muted: '#666666',
  surface: '#ececff',
  border: '#9370db',
};
const themeOptions =
  diagramTheme == null
    ? DEFAULT_DIAGRAM_COLORS
    : typeof diagramTheme === 'object'
      ? diagramTheme
      : (THEMES[diagramTheme] ?? DEFAULT_DIAGRAM_COLORS);

// beautiful-mermaid renders Mermaid to an SVG string synchronously on the
// server — no browser, no client-side hydration. It throws on empty or invalid
// input and on unsupported diagram types (gantt, pie, mindmap, gitGraph, …); in
// that case we fall back to the raw source in a <pre> so content is never lost.
let svg: string | null = null;
if (!DiagramComp && source) {
  try {
    const out = renderMermaidSVG(source, themeOptions);
    svg = typeof out === 'string' && out.includes('<svg') ? out : null;
  } catch {
    svg = null;
  }
}
const Custom = DiagramComp as any;
---

{
  Custom ? (
    <Custom code={source} format={format} />
  ) : svg !== null ? (
    <div class="mermaid-diagram" set:html={svg} />
  ) : (
    <pre class="mermaid-source">{source}</pre>
  )
}
