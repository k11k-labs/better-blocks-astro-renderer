---
import { BlocksRenderer, type BlocksContent } from '@k11k/better-blocks-astro-renderer';
import 'katex/dist/katex.min.css';
import CustomCallout from '../components/CustomCallout.astro';

interface Article {
  id: number;
  documentId: string;
  content: BlocksContent;
}

const STRAPI_URL = process.env.STRAPI_URL || 'http://localhost:1337';

let articles: Article[] = [];
let error: string | null = null;

try {
  const res = await fetch(`${STRAPI_URL}/api/articles?status=published`);
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const json = await res.json();
  articles = json.data.map((item: Article) => ({
    id: item.id,
    documentId: item.documentId,
    content: item.content,
  }));
} catch (err) {
  error = err instanceof Error ? err.message : String(err);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Better Blocks Renderer Playground</title>
  </head>
  <body>
    <div style="max-width: 720px; margin: 0 auto; padding: 24px; font-family: system-ui;">
      <h1>Better Blocks Renderer Playground</h1>
      <p style="color: #666; margin-bottom: 32px;">
        Fetching articles from Strapi at <code>localhost:1337</code> and rendering with
        <code>@k11k/better-blocks-astro-renderer</code> — native Astro, zero client-side JavaScript.
      </p>

      {
        error && (
          <p style="color: red;">
            Error: {error}. Make sure Strapi is running on port 1337.
          </p>
        )
      }

      {
        !error && articles.length === 0 && (
          <p>
            No published articles found. Create one in
            <a href="http://localhost:1337/admin" target="_blank" rel="noopener noreferrer">
              Strapi admin
            </a>
            and publish it.
          </p>
        )
      }

      {
        articles.map((article) => {
          // Pull just the callout blocks so the custom-renderer demo below is
          // focused on callouts (not a second copy of the whole article).
          const callouts = article.content.filter((block) => block.type === 'callout');

          return (
            <article style="margin-bottom: 48px; border-bottom: 1px solid #eee; padding-bottom: 24px;">
              <h2 style="color: #888; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em;">
                ① Default rendering — callouts are GitHub-style
              </h2>
              <BlocksRenderer content={article.content} />

              {callouts.length > 0 && (
                <section style="margin-top: 40px; padding-top: 16px; border-top: 2px dashed #d7c7ff;">
                  <h2 style="color: #7c3aed; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em;">
                    ② Custom callout renderer — same callouts via the <code>blocks</code> override
                  </h2>
                  <p style="color: #666; font-size: 14px; margin-top: 0;">
                    The callouts below are the exact same content as above, re-rendered with a
                    custom <code>callout</code> component (purple boxes with emoji) instead of the
                    built-in GitHub-style default.
                  </p>
                  <BlocksRenderer content={callouts} blocks={{ callout: CustomCallout }} />
                </section>
              )}
            </article>
          );
        })
      }
    </div>
  </body>
</html>
