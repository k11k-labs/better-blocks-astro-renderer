---
import { BlocksRenderer, type BlocksContent } from '@k11k/better-blocks-astro-renderer';
import 'katex/dist/katex.min.css';

interface Article {
  id: number;
  documentId: string;
  content: BlocksContent;
}

const STRAPI_URL = process.env.STRAPI_URL || 'http://localhost:1337';

let articles: Article[] = [];
let error: string | null = null;

try {
  const res = await fetch(`${STRAPI_URL}/api/articles?status=published`);
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const json = await res.json();
  articles = json.data.map((item: Article) => ({
    id: item.id,
    documentId: item.documentId,
    content: item.content,
  }));
} catch (err) {
  error = err instanceof Error ? err.message : String(err);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Better Blocks Renderer Playground</title>
  </head>
  <body>
    <div style="max-width: 720px; margin: 0 auto; padding: 24px; font-family: system-ui;">
      <h1>Better Blocks Renderer Playground</h1>
      <p style="color: #666; margin-bottom: 32px;">
        Fetching articles from Strapi at <code>localhost:1337</code> and rendering with
        <code>@k11k/better-blocks-astro-renderer</code> — native Astro, zero client-side JavaScript.
      </p>

      {
        error && (
          <p style="color: red;">
            Error: {error}. Make sure Strapi is running on port 1337.
          </p>
        )
      }

      {
        !error && articles.length === 0 && (
          <p>
            No published articles found. Create one in
            <a href="http://localhost:1337/admin" target="_blank" rel="noopener noreferrer">
              Strapi admin
            </a>
            and publish it.
          </p>
        )
      }

      {
        articles.map((article) => (
          <article style="margin-bottom: 48px; border-bottom: 1px solid #eee; padding-bottom: 24px;">
            <BlocksRenderer content={article.content} />
          </article>
        ))
      }
    </div>
  </body>
</html>
