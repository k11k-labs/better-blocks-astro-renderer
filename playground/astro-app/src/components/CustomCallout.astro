---
// A custom callout renderer that fully replaces the default GitHub-style markup.
// It receives `variant` and `title`; nested children arrive via <slot />.
const { variant, title } = Astro.props;

const EMOJI: Record<string, string> = {
  note: 'ℹ️',
  tip: '💡',
  important: '📣',
  warning: '⚠️',
  caution: '🛑',
};
---

<div
  style="border-radius: 8px; padding: 12px 16px; margin: 16px 0; background: #f4f0ff; border: 1px solid #d7c7ff;"
>
  <div style="font-weight: 700; margin-bottom: 4px;">
    {EMOJI[variant] ?? '🔖'} {title ?? variant.toUpperCase()}
  </div>
  <slot />
</div>
